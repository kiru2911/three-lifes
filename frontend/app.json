{
  "expo": {
    "name": "Thinkly",
    "slug": "thinkly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "thinkly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#534AB7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thinkly.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#534AB7"
      },
      "package": "com.thinkly.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
